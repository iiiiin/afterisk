{
  "manifest_version": 3,
  "name": "Afterisk",
  "version": "1.0.0",
  "description": "Detects leftover markdown symbols after pasting AI-generated text.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_icon": {
      "16": "icons/icon_off-16.png",
      "32": "icons/icon_off-32.png",
      "48": "icons/icon_off-48.png",
      "128": "icons/icon_off-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon_off-16.png",
    "32": "icons/icon_off-32.png",
    "48": "icons/icon_off-48.png",
    "128": "icons/icon_off-128.png"
  }
}